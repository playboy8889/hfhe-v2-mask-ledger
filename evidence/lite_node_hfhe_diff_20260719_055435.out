## selected added lines recrypt/HFHE since b380d88 (first 220)
+external serialize_cipher_public : cipher -> bytes = "caml_pvac_serialize_cipher_public"
+val serialize_cipher_public : cipher -> bytes
+static constexpr uint8_t VERSION_V4 = 0x04;
+    void header_version(uint8_t tag, uint8_t version) {
+        u8(version);
+    void header(uint8_t tag) { header_version(tag, VERSION); }
+        if (ver != VERSION_V1 && ver != VERSION_V2 && ver != VERSION_V3 && ver != VERSION_V4) { fail("pvac_ser: bad version"); return 0; }
+inline void write_layer_public(Writer& w, const pvac::Layer& L) {
+    w.u8(static_cast<uint8_t>(L.rule));
+    if (L.rule == pvac::RRule::BASE) {
+        w.u64(L.seed.ztag);
+        w.u64(L.seed.nonce.lo);
+        w.u64(L.seed.nonce.hi);
+    } else {
+        w.u32(L.pa);
+        w.u32(L.pb);
+    }
+}
+inline void mark_public_base_layer(pvac::Layer& L, size_t slots) {
+    if (L.rule == pvac::RRule::BASE) {
+        L.R_com = {};
+        L.R_PC.assign(slots, {});
+        L.PC.clear();
+    }
+}
+inline pvac::Layer read_layer(Reader& r, uint8_t ver = VERSION_V2, size_t slots = 0) {
+    if (ver < VERSION_V4)
+        r.raw(L.R_com.data(), 32);
+    if (ver >= VERSION_V3 && ver < VERSION_V4) {
+    if (ver >= VERSION_V2 && ver < VERSION_V4) {
+    if (ver >= VERSION_V4)
+        mark_public_base_layer(L, slots);
+inline std::vector<uint8_t> serialize_cipher_public(const pvac::Cipher& C) {
+    validate_cipher_structure(C);
+    Writer w;
+    w.header_version(TAG_CIPHER, VERSION_V4);
+    w.u64(C.slots);
+    w.u64(C.L.size());
+    for (const auto& L : C.L) write_layer_public(w, L);
+    w.u64(C.c0.size());
+    for (const auto& x : C.c0) w.fp(x);
+    w.u64(C.E.size());
+    for (const auto& e : C.E) write_edge(w, e);
+    return std::move(w.buf);
+}
+        for (size_t i = 0; i < nL; ++i) C.L[i] = read_layer(r, ver, C.slots);
+    if (r.remaining() != 0) throw std::runtime_error("pvac_ser: trailing cipher bytes");
+        for (size_t i = 0; i < nL; ++i) C.L[i] = read_layer(r, ver, C.slots);
+#include <pvac_serialize.hpp>
+static bool read_layer_safe(pvac_ser::Reader& r, uint8_t ver, pvac::Layer& layer, size_t slots) {
+    if (ver < pvac_ser::VERSION_V4)
+        r.raw(layer.R_com.data(), 32);
+    if (ver >= pvac_ser::VERSION_V3 && ver < pvac_ser::VERSION_V4) {
+    if (ver >= pvac_ser::VERSION_V2 && ver < pvac_ser::VERSION_V4) {
+    if (ver >= pvac_ser::VERSION_V4)
+        pvac_ser::mark_public_base_layer(layer, slots);
+        if (!read_layer_safe(r, ver, cipher.L[i], cipher.slots))
+    if ((k.lo | k.hi) == 0) caml_failwith("pvac: zero divisor");
+        *result = pvac::ct_div_const(pk, ct, k);
+CAMLprim value caml_pvac_serialize_cipher_public(value v_ct) {
+    CAMLparam1(v_ct);
+    CAMLlocal1(v_bytes);
+    DBG_ENTER("serialize_cipher_public");
+    pvac::Cipher& ct = *Handle_val(pvac::Cipher, v_ct);
+    std::vector<uint8_t> buf;
+    try {
+        buf = pvac_ser::serialize_cipher_public(ct);
+    } catch (const std::exception& e) {
+        caml_failwith(e.what());
+    }
+    DBG_SIZE("buf_bytes", buf.size());
+    v_bytes = caml_alloc_string(buf.size());
+    std::memcpy(Bytes_val(v_bytes), buf.data(), buf.size());
+    DBG_EXIT("serialize_cipher_public");
+    CAMLreturn(v_bytes);
+}
+                ct->L[i] = pvac_ser::read_layer(r, ver, ct->slots);
